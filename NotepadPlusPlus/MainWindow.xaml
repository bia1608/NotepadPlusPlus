<Window x:Class="NotepadPlusPlus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notepad++" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Grid>
        <DockPanel>
            <Menu DockPanel.Dock="Top" Background="#F0F0F0" Padding="2">
                <MenuItem Header="File">
                    <MenuItem Header="New" InputGestureText="Ctrl+N" />
                    <MenuItem Header="Open..." InputGestureText="Ctrl+O" />
                    <MenuItem Header="Save" InputGestureText="Ctrl+S" />
                    <Separator />
                    <MenuItem Header="Exit" />
                </MenuItem>

                <MenuItem Header="Edit">
                    <MenuItem Header="Undo" InputGestureText="Ctrl+Z" />
                    <MenuItem Header="Redo" InputGestureText="Ctrl+Y" />
                    <Separator />
                    <MenuItem Header="Cut" InputGestureText="Ctrl+X" />
                    <MenuItem Header="Copy" InputGestureText="Ctrl+C" />
                    <MenuItem Header="Paste" InputGestureText="Ctrl+V" />
                </MenuItem>

                <MenuItem Header="Search">
                    <MenuItem Header="Find..." InputGestureText="Ctrl+F" />
                    <MenuItem Header="Replace..." InputGestureText="Ctrl+H" />
                </MenuItem>

                <MenuItem Header="View">
                    <MenuItem Header="Always on Top" IsCheckable="True" />
                    <MenuItem Header="Full Screen Mode" />
                </MenuItem>

                <MenuItem Header="Encoding">
                    <MenuItem Header="ANSI" />
                    <MenuItem Header="UTF-8" IsChecked="True" />
                    <MenuItem Header="UTF-8 with BOM" />
                </MenuItem>

                <MenuItem Header="Language">
                    <MenuItem Header="C" />
                    <MenuItem Header="C++" />
                    <MenuItem Header="C#" />
                    <MenuItem Header="Java" />
                    <MenuItem Header="Python" />
                </MenuItem>

                <MenuItem Header="Settings">
                    <MenuItem Header="Preferences..." />
                    <MenuItem Header="Style Configurator..." />
                </MenuItem>

                <MenuItem Header="Tools" />
                <MenuItem Header="Macro" />
            </Menu>

            <ToolBarTray DockPanel.Dock="Top">
                <ToolBar Band="1" Background="#FFDDDDDD">
                    <Button Content="New" Padding="5,0" />
                    <Button Content="Open" Padding="5,0" />
                    <Button Content="Save" Padding="5,0" />
                    <Separator />
                    <Button Content="Cut" />
                    <Button Content="Copy" />
                    <Button Content="Paste" />
                </ToolBar>
            </ToolBarTray>

            <TextBox AcceptsReturn="True" AcceptsTab="True" 
                     VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Auto" 
                     FontFamily="Consolas" FontSize="14" />
        </DockPanel>
    </Grid>
</Window>