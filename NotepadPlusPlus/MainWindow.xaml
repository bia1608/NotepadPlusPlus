<Window x:Class="NotepadPlusPlus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notepad++" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Grid>
        <DockPanel>
            <Menu DockPanel.Dock="Top" Background="#F0F0F0" Padding="2">
                <MenuItem Header="File">
                    <MenuItem Header="New" Click="NewFileButton_Click" InputGestureText="Ctrl+N" />
                    <MenuItem Header="Open..." InputGestureText="Ctrl+O" />
                    <MenuItem Header="Save" InputGestureText="Ctrl+S" />
                    <Separator />
                    <MenuItem Header="Exit" />
                </MenuItem>

                <MenuItem Header="Edit">
                    <MenuItem Header="Undo" InputGestureText="Ctrl+Z" />
                    <MenuItem Header="Redo" InputGestureText="Ctrl+Y" />
                    <Separator />
                    <MenuItem Header="Cut" InputGestureText="Ctrl+X" />
                    <MenuItem Header="Copy" InputGestureText="Ctrl+C" />
                    <MenuItem Header="Paste" InputGestureText="Ctrl+V" />
                </MenuItem>

                <MenuItem Header="Search">
                    <MenuItem Header="Find..." InputGestureText="Ctrl+F" />
                    <MenuItem Header="Replace..." InputGestureText="Ctrl+H" />
                </MenuItem>

                <MenuItem Header="View">
                    <MenuItem Header="Always on Top" IsCheckable="True" />
                    <MenuItem Header="Full Screen Mode" />
                </MenuItem>

                <MenuItem Header="Encoding">
                    <MenuItem Header="ANSI" />
                    <MenuItem Header="UTF-8" IsChecked="True" />
                    <MenuItem Header="UTF-8 with BOM" />
                </MenuItem>

                <MenuItem Header="Language">
                    <MenuItem Header="C" />
                    <MenuItem Header="C++" />
                    <MenuItem Header="C#" />
                    <MenuItem Header="Java" />
                    <MenuItem Header="Python" />
                </MenuItem>

                <MenuItem Header="Settings">
                    <MenuItem Header="Preferences..." />
                    <MenuItem Header="Style Configurator..." />
                </MenuItem>

                <MenuItem Header="Tools" />
                <MenuItem Header="Macro" />
            </Menu>

            <ToolBarTray DockPanel.Dock="Top">
                <ToolBar Band="1" Background="#FFDDDDDD">
                    <Button Padding="5,0" Click="NewFileButton_Click" ToolTip="New">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8A5;" />
                    </Button>
                    <Button Padding="5,0" ToolTip="Open">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8E5;" />
                    </Button>
                    <Button Padding="5,0" ToolTip="Open Folder">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE838;" />
                    </Button>
                    <Button Padding="5,0" ToolTip="Save">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE74E;" />
                    </Button>
                    <Button Padding="5,0" ToolTip="Save As">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE792;" />
                    </Button>
                    <Separator />
                    <Button Padding="5,0" ToolTip="Cut">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8C6;" />
                    </Button>
                    <Button Padding="5,0" ToolTip="Copy">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8C8;" />
                    </Button>
                    <Button Padding="5,0" ToolTip="Paste">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE77F;" />
                    </Button>
                </ToolBar>
            </ToolBarTray>

            <StatusBar DockPanel.Dock="Bottom" Background="#F0F0F0">
                <StatusBarItem>
                    <TextBlock Text="Normal text file" />
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="length : " />
                        <TextBlock Text="0" FontWeight="Bold" />
                        <TextBlock Text="  lines : " Margin="10,0,0,0" />
                        <TextBlock Text="1" FontWeight="Bold" />
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock Text="Ln : 1  Col : 1 | Pos : 1" Margin="0,0,20,0" />
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock Text="Windows (CR LF)" Margin="0,0,10,0" />
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock Text="UTF-8" Margin="0,0,10,0" />
                </StatusBarItem>
            </StatusBar>

            <TabControl x:Name="EditorsTabControl">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                            <Button Content="×" Command="{Binding CloseCommand}" 
                        Margin="5,0,0,0" Padding="2,0" Background="Transparent" BorderThickness="0" />
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Background="#F0F0F0" Width="40">
                                <TextBlock Text="1" Foreground="#999999" HorizontalAlignment="Center" FontFamily="Consolas" />
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" 
                         AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" BorderThickness="0"/>
                        </Grid>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>
    </Grid>
</Window>