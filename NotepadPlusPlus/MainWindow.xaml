<Window x:Class="NotepadPlusPlus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notepad++" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="UnsavedTabItemStyle" TargetType="TabItem">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSaved}" Value="False">
                    <Setter Property="Background" Value="#FFE6B3" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="TabTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSaved}" Value="False">
                    <Setter Property="Foreground" Value="Red" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate x:Key="FileSystemTemplate" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,5,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE8A5;" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                    <Setter Property="Text" Value="&#xE8B7;" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding Name}" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

        <DockPanel>
            <Menu DockPanel.Dock="Top" Background="#F0F0F0" Padding="2">
                <MenuItem Header="File">
                    <MenuItem Header="New" Click="NewFileButton_Click" InputGestureText="Ctrl+N" />
                    <MenuItem Header="Open..." Click="OpenFileButton_Click" InputGestureText="Ctrl+O" />
                    <MenuItem Header="Open Folder..." Click="OpenFolderButton_Click" InputGestureText="Ctrl+K Ctrl+O" />
                    <MenuItem Header="Save" Click="SaveFileButton_Click" InputGestureText="Ctrl+S" />
                    <MenuItem Header="Save As" Click="SaveAsFileButton_Click" InputGestureText="Ctrl+S" />
                    <Separator />
                    <MenuItem Header="Close all files" />
                    <MenuItem Header="Exit" />
                </MenuItem>

                <MenuItem Header="Edit">
                    <MenuItem Header="Undo" Click="UndoButton_Click" InputGestureText="Ctrl+Z" />
                    <MenuItem Header="Redo" Click="RedoButton_Click" InputGestureText="Ctrl+Y" />
                    <Separator />
                    <MenuItem Header="Cut" Click="CutButton_Click" InputGestureText="Ctrl+X" />
                    <MenuItem Header="Copy" Click="CopyButton_Click" InputGestureText="Ctrl+C" />
                    <MenuItem Header="Paste" Click="PasteButton_Click" InputGestureText="Ctrl+V" />
                </MenuItem>

            <MenuItem Header="Search" Click="SearchButton_Click"/>

            <MenuItem Header="View">
                    <MenuItem Header="Toggle Folder Explorer" Click="ToggleFolderExplorer_Click" IsCheckable="True" x:Name="FolderExplorerMenuItem" />
                </MenuItem>

                <MenuItem Header="Help">
                    <MenuItem Header="About" />
                </MenuItem>
            </Menu>

            <ToolBarTray DockPanel.Dock="Top">
                <ToolBar Band="1" Background="#FFDDDDDD">
                    <Button Padding="5,0" Click="NewFileButton_Click" ToolTip="New">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8A5;" />
                    </Button>
                    <Button Padding="5,0" Click="OpenFileButton_Click" ToolTip="Open">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8E5;" />
                    </Button>
                    <Button Padding="5,0" Click="OpenFolderButton_Click" ToolTip="Open Folder">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE838;" />
                    </Button>
                    <Button Padding="5,0" Click="SaveFileButton_Click" ToolTip="Save">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE74E;" />
                    </Button>
                    <Button Padding="5,0" Click="SaveAsFileButton_Click" ToolTip="Save As">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE792;" />
                    </Button>
                    <Separator />
                    <Button Padding="5,0" Click="UndoButton_Click" ToolTip="Undo">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE7A7;" />
                    </Button>
                    <Button Padding="5,0" Click="RedoButton_Click" ToolTip="Redo">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE7A6;" />
                    </Button>
                    <Button Padding="5,0" Click="CutButton_Click" ToolTip="Cut">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8C6;" />
                    </Button>
                    <Button Padding="5,0" Click="CopyButton_Click" ToolTip="Copy">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8C8;" />
                    </Button>
                    <Button Padding="5,0" Click="PasteButton_Click" ToolTip="Paste">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE77F;" />
                    </Button>
                </ToolBar>
            </ToolBarTray>

            <StatusBar DockPanel.Dock="Bottom" Background="#F0F0F0">
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Length : " />
                        <TextBlock Text="0" FontWeight="Bold" />
                        <TextBlock Text="  lines : " Margin="10,0,0,0" />
                        <TextBlock Text="1" FontWeight="Bold" />
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock Text="Ln : 1  Col : 1 | Pos : 1" Margin="0,0,20,0" />
                </StatusBarItem>
            </StatusBar>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" x:Name="FolderExplorerColumn" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Background="#F5F5F5" x:Name="FolderExplorerPanel">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Folder explorer" FontWeight="Bold" 
                                   Padding="10,5" Background="#E0E0E0" />
                        <TreeView x:Name="FolderTreeView" 
                                  ItemsSource="{Binding Folders}"
                                  ItemTemplate="{StaticResource FileSystemTemplate}"
                                  SelectedItemChanged="FolderTreeView_SelectedItemChanged"
                                  BorderThickness="0" 
                                  Background="Transparent">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                        <TreeView.ContextMenu>
                            <ContextMenu x:Name="ExplorerMenu">
                                <MenuItem Header="New file" Click="NewFile_Click" />
                                <MenuItem Header="Copy path" Click="CopyPath_Click" />
                                <Separator />
                                <MenuItem Header="Copy folder" Click="CopyFolder_Click" />
                                <MenuItem Header="Paste folder" x:Name="PasteMenuItem" Click="PasteFolder_Click" IsEnabled="False" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                    </DockPanel>
                </Border>

                <!-- Main Editor Area -->
                <TabControl Grid.Column="2" x:Name="EditorsTabControl" ItemContainerStyle="{StaticResource UnsavedTabItemStyle}">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Style="{StaticResource TabTitleTextStyle}" />
                                <Button Content="×" Command="{Binding CloseCommand}" 
                            Margin="5,0,0,0" Padding="2,0" Background="Transparent" BorderThickness="0" />
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>

                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Background="#F0F0F0" Width="40">
                                    <TextBlock Text="1" Foreground="#999999" HorizontalAlignment="Center" FontFamily="Consolas" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" 
                             AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>
        </DockPanel>
</Window>